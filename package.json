{
    "name": "Waymate",
    "private": true,
    "packageManager": "bun@1.3.10",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "typecheck": "turbo typecheck",
        "db:generate": "turbo db:generate",
        "db:migrate": "turbo db:migrate",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check"
    },
    "dependencies": {
        "@elysiajs/swagger": "^1.3.1",
        "better-auth": "^1.6.3",
        "drizzle-orm": "^0.45.2",
        "postgres": "^3.4.9",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "drizzle-kit": "^0.31.10",
        "eslint": "^9.0.0",
        "prettier": "^3.0.0",
        "turbo": "^2.8.16",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.0.0"
    }
}
