{
    "name": "Waymate",
    "private": true,
    "packageManager": "bun@1.3.10",
    "workspaces": [
        "apps/*",
        "packages/*",
        "e2e"
    ],
    "scripts": {
        "db:setup": "bun scripts/db-setup.mjs",
        "dev": "turbo dev",
        "build": "turbo build",
        "typecheck": "turbo typecheck",
        "db:generate": "turbo db:generate",
        "db:migrate": "turbo db:migrate",
        "test": "bun run --cwd apps/api test:run",
        "test:e2e": "bun run --cwd e2e test",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check"
    },
    "dependencies": {
        "@supabase/ssr": "^0.10.2",
        "@supabase/supabase-js": "^2.105.3",
        "@tailwindcss/vite": "^4.2.4",
        "@waymate/ui": "^0.1.56",
        "better-auth": "^1.6.8",
        "drizzle-orm": "^0.45.2",
        "h3-js": "^4.4.0",
        "postgres": "^3.4.9",
        "resend": "^6.12.2",
        "tailwindcss": "^4.2.4",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "drizzle-kit": "^0.31.10",
        "eslint": "^9.39.4",
        "prettier": "^3.8.3",
        "turbo": "^2.9.6",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.0"
    }
}
