{
    "name": "Waymate",
    "private": true,
    "packageManager": "bun@1.3.10",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "typecheck": "turbo typecheck",
        "db:generate": "turbo db:generate",
        "db:migrate": "turbo db:migrate",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check"
    },
    "dependencies": {},
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "eslint": "^9.0.0",
        "prettier": "^3.0.0",
        "turbo": "^2.8.14",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.0.0"
    }
}
