# Where Vite's dev server proxies /api/* requests. Override this if you ran the
# API on a non-default port (e.g. PORT=3001 in apps/api/.env). Defaults to
# http://localhost:3000.
# VITE_API_PROXY_TARGET=http://localhost:3001

# Optional — base URL the Eden client uses. Defaults to /api (which then goes
# through the Vite proxy above). Set this to bypass the proxy and call the API
# directly, e.g. when running the web app against a remote API.
# VITE_API_BASE_URL=http://localhost:3001

# Optional — Better Auth endpoint base. Defaults to /api in local dev, so Vite
# strips the /api prefix and the API receives /sign-in/email, /sign-up/email,
# etc. Set this when bypassing the proxy, e.g. http://localhost:3000.
# VITE_AUTH_BASE_URL=http://localhost:3000
