# Where the same-origin /api proxy forwards requests. Vite uses this locally;
# Vercel uses the same name in apps/web/vercel.json. Override this if you ran
# the API on a non-default port (e.g. PORT=3001 in apps/api/.env). Defaults to
# http://localhost:3000 in local Vite dev. Do not include a trailing slash.
# API_PROXY_TARGET=http://localhost:3001

# Backward-compatible local-only alias accepted by vite.config.ts.
# VITE_API_PROXY_TARGET=http://localhost:3001

# Optional — base URL the Eden client uses. Defaults to /api (which then goes
# through the same-origin proxy above). Set this to bypass the proxy and call
# the API directly, e.g. when running the web app against a remote API.
# VITE_API_BASE_URL=http://localhost:3001

# Optional — Better Auth endpoint base. Defaults to /api/api/auth in local dev
# so Vite strips the first /api and the API receives /api/auth/sign-in/email,
# /api/auth/sign-up/email, etc. Set this when bypassing the proxy.
# VITE_AUTH_BASE_URL=http://localhost:3000/api/auth
