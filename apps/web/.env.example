# Where the local Vite /api proxy forwards requests. Vercel does not read this
# file; production proxying is configured in apps/web/vercel.json. Override this
# if you ran the API on a non-default port (e.g. PORT=3001 in apps/api/.env).
# Defaults to http://localhost:3000 in local Vite dev. Do not include a
# trailing slash.
# API_PROXY_TARGET=http://localhost:3001

# Backward-compatible local-only alias accepted by vite.config.ts.
# VITE_API_PROXY_TARGET=http://localhost:3001

# Optional — base URL the Eden client uses. Defaults to /api (which then goes
# through the same-origin proxy above). Set this to bypass the proxy and call
# the API directly, e.g. when running the web app against a remote API.
# VITE_API_BASE_URL=http://localhost:3001

# Optional — Better Auth endpoint base. Defaults to same-origin /api/auth.
# Set this only when bypassing the proxy.
# VITE_AUTH_BASE_URL=http://localhost:3000/api/auth

# Optional — Photon geocoding base URL. Defaults to https://photon.komoot.io
# VITE_PHOTON_BASE_URL=https://photon.komoot.io
