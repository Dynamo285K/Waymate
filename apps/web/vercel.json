{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "rewrites": [
        {
            "source": "/api/auth/:path*",
            "destination": "https://waymate-vt5d.onrender.com/api/auth/:path*"
        },
        {
            "source": "/api/:path*",
            "destination": "https://waymate-vt5d.onrender.com/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
