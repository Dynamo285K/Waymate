{
    "name": "@repo/api",
    "private": true,
    "type": "module",
    "exports": {
        ".": "./src/index.ts"
    },
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "build": "bun build src/index.ts --outdir dist --target bun",
        "start": "bun dist/index.js",
        "typecheck": "tsc -p tsconfig.json",
        "openapi:dump": "bun scripts/dump-openapi.ts",
        "seed": "bun src/db/seed.ts",
        "test": "vitest",
        "test:run": "vitest run",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:reset": "bun src/db/reset.ts",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@elysiajs/cors": "^1.4.2",
        "@elysiajs/openapi": "^1.4.15",
        "@mapbox/polyline": "^1.2.1",
        "@repo/shared": "workspace:*",
        "better-auth": "^1.6.8",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "elysia": "^1.0.0",
        "h3-js": "^4.4.0",
        "ioredis": "^5.11.1",
        "pino": "^10.3.1",
        "postgres": "^3.4.9",
        "resend": "^6.12.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/mapbox__polyline": "^1.0.5",
        "@types/node": "^25.6.0",
        "@vitest/coverage-v8": "^4.1.6",
        "drizzle-kit": "^0.31.10",
        "pino-pretty": "^13.1.3",
        "typescript": "^5.9.3",
        "vitest": "^4.1.6"
    }
}
