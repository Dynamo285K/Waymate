PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/spolujazda_db
BETTER_AUTH_URL=http://localhost:3000
WEB_ORIGIN=http://localhost:5173

# Optional — additional frontend origins allowed by CORS and trusted by
# Better Auth, comma-separated. WEB_ORIGIN is always included.
# Use this for extra production/staging hosts.
# CORS_ORIGINS=https://staging.waymate.com,https://waymate.com

# Optional — max accepted request body size in bytes. Defaults to 100 KiB.
# Requests exceeding this are rejected with HTTP 413 before the body is read.
# MAX_REQUEST_BODY_BYTES=102400

# Optional — number of trusted reverse proxies in front of the API. Defaults
# to 1. The rate limiter reads the client IP this many entries from the end of
# X-Forwarded-For; set it to the real hop count so clients can't spoof their
# bucket by prefilling the header.
# TRUSTED_PROXY_COUNT=1

# Optional — pino log level. Defaults to "info". Use "debug" locally if you
# want to see request-scoped debug lines. Valid: trace, debug, info, warn,
# error, fatal, silent.
# LOG_LEVEL=info

# Optional — controls log formatting. Pretty (human-readable) in
# "development", JSON otherwise. Defaults to "development".
# NODE_ENV=development

# RESEND_API_KEY=re_...

# Optional — Google OAuth login is enabled only when both are set.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
